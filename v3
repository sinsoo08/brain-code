/* 소뇌 */
function startCerebellumGame(keepScore = 0, keepLevel = 2, keepFail = 0) {
  clearGameTimers();
  mode = "game";
  currentRegion = "소뇌";
  homeBtn.style.display = "inline-block";
  titleText.textContent = "🟩 소뇌 게임";
  brainText.textContent = "현재 위치: 소뇌 게임";

  const holes = [];
  const startX = 330;
  const startY = 170;
  const gapX = 190;
  const gapY = 145;

  for (let row = 0; row < 3; row++) {
    for (let col = 0; col < 3; col++) {
      holes.push({
        x: startX + col * gapX,
        y: startY + row * gapY,
        r: 60
      });
    }
  }

  gameData = {
    score: keepScore,
    level: keepLevel,
    failCount: keepFail,
    holes,
    activeIndex: Math.floor(Math.random() * holes.length),
    hitCount: 0,
    targetHits: keepLevel <= 1 ? 6 : keepLevel === 2 ? 8 : 10,
    startTime: Date.now(),
    elapsed: 0,
    moleUp: true,
    isHitEffect: false
  };

  updateGuideText();

  gameInterval = setInterval(() => {
    if (!gameData || currentRegion !== "소뇌") return;
    gameData.elapsed = ((Date.now() - gameData.startTime) / 1000).toFixed(1);
    drawCerebellumGame();
  }, 100);

  drawCerebellumGame();
  speak("게임을 시작합니다");
}

function moveNextMole() {
  if (!gameData || currentRegion !== "소뇌") return;
  let next = Math.floor(Math.random() * gameData.holes.length);
  while (next === gameData.activeIndex && gameData.holes.length > 1) {
    next = Math.floor(Math.random() * gameData.holes.length);
  }
  gameData.activeIndex = next;
  gameData.moleUp = true;
  gameData.isHitEffect = false;
  drawCerebellumGame();
}

function drawCerebellumGame() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.textAlign = "center";
  ctx.textBaseline = "middle";
  ctx.font = "30px Pretendard, Jua, sans-serif";
  ctx.fillStyle = "#2f3b48";
  ctx.fillText("잡은 수: " + gameData.hitCount + " / " + gameData.targetHits, 260, 70);
  ctx.fillText("시간: " + gameData.elapsed + "초", 870, 70);
  ctx.fillText("점수: " + gameData.score, 1030, 110);

  for (let i = 0; i < gameData.holes.length; i++) {
    const h = gameData.holes[i];

    ctx.fillStyle = "#c6a98b";
    ctx.beginPath();
    ctx.ellipse(h.x, h.y + 24, h.r, 34, 0, 0, Math.PI * 2);
    ctx.fill();

    if (i === gameData.activeIndex && gameData.moleUp) {
      if (gameData.isHitEffect) {
        ctx.fillStyle = pastelOrange;
        ctx.beginPath();
        ctx.arc(h.x, h.y - 15, 42, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = "#31404d";
        ctx.font = "24px Pretendard, Jua, sans-serif";
        ctx.fillText("성공!", h.x, h.y - 18);
      } else {
        ctx.fillStyle = "#b78f67";
        ctx.beginPath();
        ctx.arc(h.x, h.y - 15, 42, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = "#ffffff";
        ctx.beginPath();
        ctx.arc(h.x - 12, h.y - 22, 5, 0, Math.PI * 2);
        ctx.arc(h.x + 12, h.y - 22, 5, 0, Math.PI * 2);
        ctx.fill();

        ctx.strokeStyle = "#31404d";
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(h.x, h.y - 8, 12, 0, Math.PI);
        ctx.stroke();
      }
    }
  }
}

function startRegionGame(region) {
  hoveredRegion = "";
  clearGameTimers();
  if (region === "전두엽") startFrontalGame();
  else if (region === "두정엽") startParietalGame();
  else if (region === "측두엽") startTemporalGame();
  else if (region === "후두엽") startOccipitalGame();
  else if (region === "소뇌") startCerebellumGame();
}

function getCanvasPoint(clientX, clientY) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  return {
    x: (clientX - rect.left) * scaleX,
    y: (clientY - rect.top) * scaleY
  };
}

function handleMapMove(px, py) {
  if (mode !== "map") return;

  const realX = Math.round((px - imgX) / scale);
  const realY = Math.round((py - imgY) / scale);

  coordsText.textContent = `좌표: (${realX}, ${realY})`;
  const region = getRegionName(realX, realY);
  hoveredRegion = region;
  brainText.textContent = region ? "현재 위치: " + region : "현재 위치: 없음";
  drawMap(px, py);
}

function handleCanvasClick(px, py) {
  if (mode === "map") {
    const realX = Math.round((px - imgX) / scale);
    const realY = Math.round((py - imgY) / scale);
    const region = getRegionName(realX, realY);
    if (region) startRegionGame(region);
    return;
  }

  if (mode !== "game") return;

  if (currentRegion === "전두엽") {
    for (const c of gameData.round.choices) {
      if (px >= c.x && px <= c.x + c.w && py >= c.y && py <= c.y + c.h) {
        if (c.correct) {
          gameData.score++;
          registerSuccess();
          showMessage("정답이야! 잘했어");
          speak("잘했어요");
        } else {
          registerFailure();
          showMessage("한번 더 해볼까요?");
          speak("괜찮아요, 다시 해봐요");
        }
        makeFrontalRound();
        drawFrontalGame();
        return;
      }
    }
  }

  if (currentRegion === "두정엽") {
    for (let i = 0; i < gameData.shapes.length; i++) {
      const s = gameData.shapes[i];
      if (!isShapeHit(px, py, s)) continue;

      if (!gameData.selected.includes(i)) {
        gameData.selected.push(i);
      }

      drawParietalGame();

      if (gameData.selected.length === 2) {
        const a = gameData.shapes[gameData.selected[0]];
        const b = gameData.shapes[gameData.selected[1]];
        setTimeout(() => {
          if (a.type === b.type) {
            gameData.score++;
            registerSuccess();
            showMessage("정답이야! 잘했어");
            speak("잘했어요");
          } else {
            registerFailure();
            showMessage("한번 더 해볼까요?");
            speak("괜찮아요, 다시 해봐요");
          }
          makeParietalRound();
          drawParietalGame();
        }, 300);
      }
      return;
    }
  }

  if (currentRegion === "측두엽") {
    if (gameData.showing) return;

    for (const b of gameData.buttons) {
      if (px >= b.x && px <= b.x + b.w && py >= b.y && py <= b.y + b.h) {
        gameData.userInput.push(b.num);
        drawTemporalGame();

        const idx = gameData.userInput.length - 1;
        if (gameData.userInput[idx] !== gameData.sequence[idx]) {
          registerFailure();
          showMessage("괜찮아요, 다시 해봐요 :)", 1600);
          speak("괜찮아요, 다시 해봐요");
          makeTemporalRound();
          showTemporalSequence(0);
          return;
        }

        if (gameData.userInput.length === gameData.sequence.length) {
          gameData.score++;
          registerSuccess();
          showMessage("정답이야! 잘했어", 1400);
          speak("잘했어요");
          makeTemporalRound();
          showTemporalSequence(0);
        }
        return;
      }
    }
  }

  if (currentRegion === "후두엽") {
    if (gameData.lock) return;

    for (const c of gameData.cards) {
      if (px >= c.x && px <= c.x + c.w && py >= c.y && py <= c.y + c.h) {
        if (c.open || c.matched) return;

        c.open = true;

        if (!gameData.first) {
          gameData.first = c;
        } else if (!gameData.second && c !== gameData.first) {
          gameData.second = c;
          gameData.lock = true;

          if (gameData.first.value === gameData.second.value) {
            gameData.first.matched = true;
            gameData.second.matched = true;
            gameData.first = null;
            gameData.second = null;
            gameData.lock = false;
            gameData.matched++;
            drawOccipitalGame();

            const totalPairs = gameData.cards.length / 2;
            if (gameData.matched >= totalPairs) {
              gameData.score++;
              registerSuccess();
              showMessage("정답이야! 잘했어");
              speak("잘했어요");
              setTimeout(() => {
                makeOccipitalRound();
                drawOccipitalGame();
              }, 500);
            }
          } else {
            registerFailure();
            speak("괜찮아요, 다시 해봐요");
            drawOccipitalGame();
            setTimeout(() => {
              gameData.first.open = false;
              gameData.second.open = false;
              gameData.first = null;
              gameData.second = null;
              gameData.lock = false;
              showMessage("한번 더 해볼까요?");
              drawOccipitalGame();
            }, 700);
          }
        }
        drawOccipitalGame();
        return;
      }
    }
  }

  if (currentRegion === "소뇌") {
    const activeHole = gameData.holes[gameData.activeIndex];
    const dx = px - activeHole.x;
    const dy = py - (activeHole.y - 15);

    if (gameData.moleUp && dx * dx + dy * dy <= 60 * 60) {
      gameData.hitCount++;
      gameData.elapsed = ((Date.now() - gameData.startTime) / 1000).toFixed(1);
      gameData.isHitEffect = true;
      drawCerebellumGame();

      if (gameData.hitCount >= gameData.targetHits) {
        clearInterval(gameInterval);
        gameInterval = null;
        gameData.score++;
        registerSuccess();
        showMessage("잘했어요! 다음 판 시작합니다", 1500);
        speak("훌륭해요! 다음 게임으로 가볼까요?");
        setTimeout(() => {
          startCerebellumGame(gameData.score, gameData.level, gameData.failCount);
        }, 900);
      } else {
        setTimeout(() => {
          moveNextMole();
        }, 350);
      }
    }
  }
}

canvas.addEventListener("mousemove", (e) => {
  handleMapMove(e.offsetX, e.offsetY);
});

canvas.addEventListener("mouseleave", () => {
  if (mode !== "map") return;
  hoveredRegion = "";
  brainText.textContent = "현재 위치: 없음";
  coordsText.textContent = "좌표: (0, 0)";
  drawMap();
});

canvas.addEventListener("click", (e) => {
  handleCanvasClick(e.offsetX, e.offsetY);
});

canvas.addEventListener("touchmove", (e) => {
  e.preventDefault();
  const t = e.touches[0];
  const p = getCanvasPoint(t.clientX, t.clientY);
  handleMapMove(p.x, p.y);
}, { passive: false });

canvas.addEventListener("touchend", (e) => {
  e.preventDefault();
  const t = e.changedTouches[0];
  const p = getCanvasPoint(t.clientX, t.clientY);
  handleCanvasClick(p.x, p.y);
}, { passive: false });

img.onload = () => {
  resizeCanvasView();
  drawMap();
  showMessage("하고 싶은 게임을 눌러보세요", 0);
  speak("하고 싶은 게임을 눌러보세요");
};
</script>
