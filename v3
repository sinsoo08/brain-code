/* 후두엽 */
function makeOccipitalRound() {
  const values = gameData.level <= 1
    ? ["●", "▲", "●", "▲"]
    : ["●", "▲", "■", "★", "●", "▲", "■", "★"];

  const mixed = shuffle(values);
  gameData.cards = [];
  gameData.first = null;
  gameData.second = null;
  gameData.lock = false;
  gameData.matched = 0;

  const cols = values.length === 4 ? 2 : 4;
  const rows = values.length === 4 ? 2 : 2;
  const w = 120;
  const h = 140;
  const gap = 28;
  const totalW = cols * w + (cols - 1) * gap;
  const startX = (canvas.width - totalW) / 2;
  const startY = 180;

  for (let i = 0; i < mixed.length; i++) {
    const row = Math.floor(i / cols);
    const col = i % cols;
    gameData.cards.push({
      x: startX + col * (w + gap),
      y: startY + row * (h + gap),
      w,
      h,
      value: mixed[i],
      open: false,
      matched: false
    });
  }
}

