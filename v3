function makeParietalRound() {
  const allTypes = ["circle", "square", "triangle", "diamond", "star"];
  const useCount = gameData.level <= 1 ? 3 : gameData.level === 2 ? 4 : 5;
  const pool = allTypes.slice(0, useCount);

  const correctType = randomItem(pool);
  const wrongs = shuffle(pool.filter(t => t !== correctType)).slice(0, 2);

  const positions = shuffle([
    { x: 190, y: 240 },
    { x: 410, y: 240 },
    { x: 630, y: 240 },
    { x: 850, y: 240 }
  ]);

  const shapes = [
    { type: correctType, x: positions[0].x, y: positions[0].y, size: 92 },
    { type: correctType, x: positions[1].x, y: positions[1].y, size: 92 },
    { type: wrongs[0], x: positions[2].x, y: positions[2].y, size: 92 },
    { type: wrongs[1] || "circle", x: positions[3].x, y: positions[3].y, size: 92 }
  ];

  gameData.shapes = shuffle(shapes);
  gameData.selected = [];
}

