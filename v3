function speak(text) {
  try {
    window.speechSynthesis.cancel();
    const msg = new SpeechSynthesisUtterance(text);
    msg.lang = "ko-KR";
    window.speechSynthesis.speak(msg);
  } catch (e) {}
}

function showMessage(text, ms = 1400) {
  messageBox.textContent = text;
  if (messageTimer) clearTimeout(messageTimer);
  if (ms > 0) {
    messageTimer = setTimeout(() => {
      if (mode === "map") messageBox.textContent = "하고 싶은 게임을 눌러보세요";
      else updateGuideText();
    }, ms);
  }
}

function clearGameTimers() {
  if (gameTimer) {
    clearTimeout(gameTimer);
    gameTimer = null;
  }
  if (gameInterval) {
    clearInterval(gameInterval);
    gameInterval = null;
  }
  if (messageTimer) {
    clearTimeout(messageTimer);
    messageTimer = null;
  }
}

function resizeCanvasView() {
  canvas.width = BASE_W;
  canvas.height = BASE_H;
  if (img.complete) {
    imgW = img.width * scale;
    imgH = img.height * scale;
    imgX = (canvas.width - imgW) / 2;
    imgY = (canvas.height - imgH) / 2;
    if (mode === "map") drawMap();
    else redrawCurrentGame();
  }
}

window.addEventListener("resize", resizeCanvasView);

