        const difficultySelect = document.getElementById("difficultySelect");
        const hardLevelSelect = document.getElementById("hardLevelSelect");
        const gameShell = document.getElementById("gameShell");
        const gameStatusBanner = document.getElementById("gameStatusBanner");

        function loadStats() {
            try {
                const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY));
                if (parsed && parsed.regions) return parsed;
            } catch (e) {}
            return defaultStats();
        }

        function saveStats() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(stats));
        }

        function loadSettings() {
            try {
                const parsed = JSON.parse(localStorage.getItem(SETTINGS_KEY));
                if (parsed) return parsed;
            } catch (e) {}
            return defaultSettings();
        }

        function saveSettings() {
            localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings));
        }

        function pointsToString(points) {
            return points.map(p => p.join(",")).join(" ");
        }

        function initRegions() {
            Object.values(regions).forEach(region => {
                const el = document.getElementById(`region-${region.key}`);
                el.setAttribute("points", pointsToString(region.points));
                el.addEventListener("click", () => selectRegion(region.key));
            });
        }

        function showScreen(name) {
            startScreen.classList.remove("active");
            mainScreen.classList.remove("active");
            if (name === "start") {
                startScreen.classList.add("active");
            } else {
                mainScreen.classList.add("active");
            }
        }

        function selectRegion(regionKey) {
            selectedRegionKey = regionKey;
            document.body.classList.add("brain-hidden");

            const region = regions[regionKey];
            const activeEl = document.getElementById(`region-${regionKey}`);

            document.querySelectorAll(".region").forEach(el => {
                el.classList.remove("active");
                el.classList.add("dimmed");
            });
            if (activeEl) {
                activeEl.classList.add("active");
                activeEl.classList.remove("dimmed");
            }

            dimOverlay.style.display = "block";
            activeMaskPolygon.setAttribute("points", pointsToString(region.points));

            startSelectedGame();
        }

        function backToBrain() {
            document.body.classList.remove("brain-hidden");
            selectedRegionKey = null;

            gameShell.innerHTML = `
            <div style="text-align:center; padding-top:150px;">
                <p style="color:var(--sub); font-size:1.2rem;">뇌의 각 영역을 클릭하여 훈련을 시작하세요.</p>
            </div>
        `;

            document.querySelectorAll(".region").forEach(el => {
                el.classList.remove("active", "dimmed");
            });
            dimOverlay.style.display = "none";
            activeMaskPolygon.setAttribute("points", "");
        }

        function renderGameLayout(title, subtitle, innerHTML) {
            gameShell.innerHTML = `
            <div class="game-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; border-bottom:1px solid var(--line); padding-bottom:15px;">
                <div>
                    <div class="game-title" style="font-size:1.8rem; font-weight:bold;">${title}</div>
                    <div class="subline" style="font-size:1.1rem; color:var(--sub);">${subtitle}</div>
                </div>
                <button class="btn strong" onclick="backToBrain()" style="padding:10px 20px; cursor:pointer;">← 다른 영역 선택</button>
            </div>
            <div class="game-content">
                ${innerHTML}
            </div>
        `;
        }

        function getDifficultyConfig() {
            const difficulty = difficultySelect.value;
            const hardLevel = Number(hardLevelSelect.value);
            return {
                difficulty,
                hardLevel: difficulty === "easy" ? 1 : hardLevel
            };
        }

        function updateDifficultyUI() {
            if (difficultySelect.value === "hard") {
                hardLevelSelect.classList.remove("hidden");
            } else {
                hardLevelSelect.classList.add("hidden");
            }
            if (selectedRegionKey) startSelectedGame();
        }

        function startSelectedGame() {
            if (!selectedRegionKey) return;
            const region = regions[selectedRegionKey];
            const {
                difficulty,
                hardLevel
            } = getDifficultyConfig();

            if (region.key === "frontal") renderFrontalGame(difficulty, hardLevel);
            if (region.key === "parietal") renderParietalGame(difficulty, hardLevel);
            if (region.key === "temporal") renderTemporalGame(difficulty, hardLevel);
            if (region.key === "occipital") renderOccipitalGame(difficulty, hardLevel);
            if (region.key === "cerebellum") renderCerebellumGame(difficulty, hardLevel);
        }

        function showStatus(text) {
            if (settings.effectText !== "on") return;
            gameStatusBanner.textContent = text;
            gameStatusBanner.classList.add("show");
            clearTimeout(showStatus._t);
            showStatus._t = setTimeout(() => {
                gameStatusBanner.classList.remove("show");
            }, 1800);
        }

        function regionStats(regionKey) {
            return stats.regions[regionKey];
        }

        function registerPlay(regionKey) {
            stats.totalPlays += 1;
            regionStats(regionKey).plays += 1;
        }

        function registerScore(regionKey, score) {
            stats.bestScore = Math.max(stats.bestScore, score);
            regionStats(regionKey).bestScore = Math.max(regionStats(regionKey).bestScore, score);
        }

        function registerAttempt(regionKey, correct, countAttempt = true) {
            if (countAttempt) {
                stats.totalAttempts += 1;
                regionStats(regionKey).attempts += 1;
            }
            if (correct) {
                stats.totalCorrect += 1;
                regionStats(regionKey).correct += 1;
            }
        }

        function registerReaction(regionKey, ms) {
            if (stats.bestReaction === null || ms < stats.bestReaction) stats.bestReaction = ms;
            const region = regionStats(regionKey);
            if (region.bestReaction === null || ms < region.bestReaction) region.bestReaction = ms;
        }

        function finishGame(regionKey, score) {
            registerScore(regionKey, score);
            saveStats();
            renderStats();
            if (settings.resultHint === "on") showStatus(`결과 저장 완료 · 점수 ${score}`);
        }

        function renderFrontalGame(difficulty, hardLevel) {
            const count = difficulty === "easy" ? 4 : Math.min(4 + hardLevel, 12);
            const numbers = Array.from({
                length: count
            }, () => Math.floor(Math.random() * 10));
            activeGameState = {
                type: "frontal",
                answer: numbers.join(""),
                shown: true,
                regionKey: "frontal"
            };

            renderGameLayout(
                "전두엽 게임 · 숫자 기억",
                "잠깐 보이는 숫자를 기억한 뒤 그대로 입력하세요.",
                `
      <div class="center-box">
        <div class="big-number" id="frontalDisplay">${numbers.join(" ")}</div>
        <div class="subline">숫자가 잠시 뒤 사라집니다.</div>
      </div>
    `
            );

            const showMs = difficulty === "easy" ? 1800 : Math.max(700, 1800 - hardLevel * 90);

            setTimeout(() => {
                if (!activeGameState || activeGameState.type !== "frontal") return;
                activeGameState.shown = false;
                renderGameLayout(
                    "전두엽 게임 · 숫자 기억",
                    "숫자를 순서대로 입력해보세요.",
                    `
      <div class="center-box">
        <div class="answer-row">
          <input class="text-input" id="frontalInput" placeholder="숫자 입력" autocomplete="off">
          <button class="btn strong" id="frontalSubmitBtn">확인</button>
        </div>
      </div>
    `
                );
                const input = document.getElementById("frontalInput");
                input.focus();
                input.addEventListener("keydown", (e) => {
                    if (e.key === "Enter") submitFrontal();
                });
                document.getElementById("frontalSubmitBtn").addEventListener("click", submitFrontal);
            }, showMs);
        }

        function submitFrontal() {
            if (!activeGameState || activeGameState.type !== "frontal") return;
            const input = document.getElementById("frontalInput");
            const val = (input.value || "").replace(/\s/g, "");
            const correct = val === activeGameState.answer;

            if (correct) registerPlay("frontal");

            registerAttempt("frontal", correct, true);
            const score = correct ? activeGameState.answer.length * 10 : 0;
            finishGame("frontal", score);

            renderGameLayout(
                "전두엽 게임 · 결과",
                correct ? "잘 기억했어요." : "아쉽지만 다시 해볼 수 있어요.",
                `
      <div class="center-box">
        <div class="big-word">${correct ? "정답!" : "오답"}</div>
        <div class="subline">정답: ${activeGameState.answer}</div>
        <div class="subline">입력: ${val || "(빈칸)"}</div>
        <button class="btn strong" id="retryFrontalBtn">다시하기</button>
      </div>
    `
            );
            document.getElementById("retryFrontalBtn").addEventListener("click", startSelectedGame);
        }

        function renderParietalGame(difficulty, hardLevel) {
            const targetIndex = Math.floor(Math.random() * 9);
            const targetRow = Math.floor(targetIndex / 3) + 1;
            const targetCol = (targetIndex % 3) + 1;
            activeGameState = {
                type: "parietal",
                regionKey: "parietal",
                targetIndex
            };

            const labels = Array.from({
                length: 9
            }, (_, i) => {
                if (difficulty === "easy") return i === targetIndex ? "★" : "○";
                return i === targetIndex ? "★" : (Math.random() < 0.5 ? "△" : "○");
            });

            renderGameLayout(
                    "두정엽 게임 · 위치 찾기",
                    `목표 위치: ${targetRow}행 ${targetCol}열`,
                    `
      <div class="center-box">
        <div class="subline">아래 칸 중 목표 위치를 눌러보세요.</div>
        <div class="quiz-grid" id="parietalGrid">
          ${labels.map((label, idx) => `<button class="quiz-cell" data-idx="${idx}">${label}</button>`).join("")}
        </div>
      </div>
    `
            );

            document.querySelectorAll("#parietalGrid .quiz-cell").forEach(btn => {
                btn.addEventListener("click", () => {
                    const idx = Number(btn.dataset.idx);
                    const correct = idx === activeGameState.targetIndex;
                    
                    if (correct) registerPlay("parietal");

                    registerAttempt("parietal", correct, true);
                    const score = correct ? (difficulty === "easy" ? 10 : 10 + hardLevel * 4) : 0;
                    finishGame("parietal", score);

                    renderGameLayout(
                        "두정엽 게임 · 결과",
                        correct ? "위치를 잘 찾았어요." : "다음에는 더 천천히 찾아보세요.",
                        `
          <div class="center-box">
            <div class="big-word">${correct ? "정답!" : "오답"}</div>
            <div class="subline">정답 위치: ${Math.floor(activeGameState.targetIndex / 3) + 1}행 ${(activeGameState.targetIndex % 3) + 1}열</div>
            <button class="btn strong" id="retryParietalBtn">다시하기</button>
          </div>
        `
                    );
                    document.getElementById("retryParietalBtn").addEventListener("click", startSelectedGame);
                });
            });
        }

        function renderTemporalGame(difficulty, hardLevel) {
            const wordSetsEasy = ["사과", "바나나", "포도"];
            const wordSetsHard = ["사과", "바나나", "포도", "수박", "복숭아", "딸기", "귤", "참외"];
            const source = difficulty === "easy" ? wordSetsEasy : wordSetsHard;
            const count = difficulty === "easy" ? 3 : Math.min(3 + Math.floor(hardLevel / 2), 7);

            const shuffled = [...source].sort(() => Math.random() - 0.5);
            const selected = shuffled.slice(0, count);

            activeGameState = { type: "temporal", regionKey: "temporal", selectedWords: selected, pickedWords: new Set() };

            renderGameLayout(
                "측두엽 게임 · 기억하기",
                "단어를 잠깐 보고 기억한 뒤, 본 단어를 모두 선택하세요.",
                `
      <div class="center-box">
        <div class="big-word" style="font-size:34px;">${selected.join(" · ")}</div>
        <div class="subline">잠시 뒤 선택 화면으로 바뀝니다.</div>
      </div>
    `
            );

            const showMs = difficulty === "easy" ? 2200 : Math.max(1000, 2200 - hardLevel * 100);

            setTimeout(() => {
                if (!activeGameState || activeGameState.type !== "temporal") return;

                const choicesBase = [...new Set([...wordSetsHard, "레몬", "자두", "배", "키위"])];
                const answers = [...activeGameState.selectedWords];
                const neededWrong = Math.max(3, 8 - answers.length);
                const wrongs = choicesBase.filter(w => !answers.includes(w)).sort(() => Math.random() - 0.5).slice(0, neededWrong);

                const choices = [...answers, ...wrongs].sort(() => Math.random() - 0.5);

                renderGameLayout(
                    "측두엽 게임 · 기억하기",
                    "아까 본 단어를 모두 눌러 선택한 뒤 확인하세요.",
                    `
        <div class="center-box">
          <div class="quiz-grid" style="grid-template-columns:repeat(3, 110px);">
            ${choices.map(word => `
              <button type="button" class="btn ghost temporal-choice" data-word="${word}" style="padding:18px 12px;">
                ${word}
              </button>
            `).join("")}
          </div>
          <button type="button" class="btn strong" id="temporalSubmitBtn">확인</button>
        </div>
      `
                );

                document.querySelectorAll(".temporal-choice").forEach(btn => {
                    btn.addEventListener("click", () => {
                        const word = btn.dataset.word;
                        if (activeGameState.pickedWords.has(word)) {
                            activeGameState.pickedWords.delete(word);
                            btn.classList.remove("selected");
                        } else {
                            activeGameState.pickedWords.add(word);
                            btn.classList.add("selected");
                        }
                    });
                });

                document.getElementById("temporalSubmitBtn").addEventListener("click", () => {
                    const answerSet = new Set(activeGameState.selectedWords);
                    const picked = activeGameState.pickedWords;

                    let correct = true;
                    if (picked.size !== answerSet.size) correct = false;
                    for (const word of answerSet) {
                        if (!picked.has(word)) {
                            correct = false;
                            break;
                        }
                    }

                    if (correct) registerPlay("temporal");

                    registerAttempt("temporal", correct, true);
                    const score = correct ? activeGameState.selectedWords.length * 10 : 0;
                    finishGame("temporal", score);

                    renderGameLayout(
                        "측두엽 게임 · 결과",
                        correct ? "기억을 잘했어요." : "조금 헷갈렸네요. 다시 해볼 수 있어요.",
                        `
          <div class="center-box">
            <div class="big-word">${correct ? "정답!" : "오답"}</div>
            <div class="subline">정답 단어: ${activeGameState.selectedWords.join(", ")}</div>
            <button class="btn strong" id="retryTemporalBtn">다시하기</button>
          </div>
        `
                    );
                    document.getElementById("retryTemporalBtn").addEventListener("click", startSelectedGame);
                });
            }, showMs);
        }

        function renderOccipitalGame(difficulty, hardLevel) {
            const shapes = ["●", "■", "▲", "◆", "★"];
            const target = shapes[Math.floor(Math.random() * shapes.length)];
            const total = 9;
            const targetCount = difficulty === "easy" ? 1 : Math.min(1 + Math.floor(hardLevel / 3), 3);
            const pool = [];

            for (let i = 0; i < targetCount; i++) pool.push(target);
            while (pool.length < total) {
                const s = shapes[Math.floor(Math.random() * shapes.length)];
                if (difficulty === "easy") {
                    if (s !== target) pool.push(s);
                } else {
                    pool.push(s);
                }
            }

            const shuffled = pool.sort(() => Math.random() - 0.5);

            activeGameState = { type: "occipital", regionKey: "occipital", target, targets: targetCount, clickedIndices: new Set(), board: shuffled };

            renderGameLayout(
                "후두엽 게임 · 같은 모양 찾기",
                `"${target}" 모양을 모두 찾아 눌러보세요.`,
                `
      <div class="center-box">
        <div class="big-word" style="font-size:40px;">찾을 모양: ${target}</div>
        <div class="visual-grid" id="occipitalGrid">
          ${shuffled.map((shape, idx) => `
            <button type="button" class="visual-card" data-idx="${idx}">${shape}</button>
          `).join("")}
        </div>
        <button type="button" class="btn strong" id="occipitalDoneBtn">확인</button>
      </div>
    `
            );

            document.querySelectorAll("#occipitalGrid .visual-card").forEach(btn => {
                btn.addEventListener("click", () => {
                    const idx = Number(btn.dataset.idx);
                    if (activeGameState.clickedIndices.has(idx)) {
                        activeGameState.clickedIndices.delete(idx);
                        btn.classList.remove("selected");
                    } else {
                        activeGameState.clickedIndices.add(idx);
                        btn.classList.add("selected");
                    }
                });
            });

            document.getElementById("occipitalDoneBtn").addEventListener("click", () => {
                const correctIndices = [];
                activeGameState.board.forEach((shape, idx) => {
                    if (shape === activeGameState.target) correctIndices.push(idx);
                });

                let correct = true;
                if (correctIndices.length !== activeGameState.clickedIndices.size) correct = false;
                for (const idx of correctIndices) {
                    if (!activeGameState.clickedIndices.has(idx)) {
                        correct = false;
                        break;
                    }
                }

                if (correct) registerPlay("occipital");

                registerAttempt("occipital", correct, true);
                const score = correct ? activeGameState.targets * 10 : 0;
                finishGame("occipital", score);

                renderGameLayout(
                    "후두엽 게임 · 결과",
                    correct ? "모양을 잘 찾았어요." : "다음에는 같은 모양을 더 자세히 살펴보세요.",
                    `
        <div class="center-box">
          <div class="big-word">${correct ? "정답!" : "오답"}</div>
          <div class="subline">찾아야 했던 모양: ${activeGameState.target}</div>
          <button class="btn strong" id="retryOccipitalBtn">다시하기</button>
        </div>
      `
                );
                document.getElementById("retryOccipitalBtn").addEventListener("click", startSelectedGame);
            });
        }

        function renderCerebellumGame(difficulty, hardLevel) {
            const waitMin = difficulty === "easy" ? 1200 : 1000;
            const waitMax = difficulty === "easy" ? 2600 : Math.max(1300, 2600 - hardLevel * 80);
            const waitMs = Math.floor(Math.random() * (waitMax - waitMin + 1)) + waitMin;

            activeGameState = { type: "cerebellum", regionKey: "cerebellum", ready: false, startedAt: null, clickedTooSoon: false };

            renderGameLayout(
                "소뇌 게임 · 반응속도",
                "기다리다가 화면이 바뀌면 바로 누르세요.",
                `
      <div class="center-box">
        <div class="reaction-box" id="reactionBox">준비... 기다려주세요</div>
      </div>
    `
            );

            const reactionBox = document.getElementById("reactionBox");

            reactionBox.addEventListener("click", () => {
                if (!activeGameState || activeGameState.type !== "cerebellum") return;

                if (!activeGameState.ready) {
                    activeGameState.clickedTooSoon = true;
                    registerAttempt("cerebellum", false, true);
                    finishGame("cerebellum", 0);
                    renderGameLayout(
                        "소뇌 게임 · 결과",
                        "너무 빨리 눌렀어요.",
                        `
          <div class="center-box">
            <div class="big-word">조금 빨랐어요</div>
            <button class="btn strong" id="retryCerebellumBtn">다시하기</button>
          </div>
        `
                    );
                    document.getElementById("retryCerebellumBtn").addEventListener("click", startSelectedGame);
                    return;
                }

                const ms = Date.now() - activeGameState.startedAt;
                
                registerPlay("cerebellum");
                registerAttempt("cerebellum", true, true);
                registerReaction("cerebellum", ms);

                let score = 0;
                if (ms <= 250) score = 30;
                else if (ms <= 400) score = 20;
                else if (ms <= 650) score = 10;
                else score = 5;

                finishGame("cerebellum", score);

                renderGameLayout(
                    "소뇌 게임 · 결과",
                    "반응속도를 기록했어요.",
                    `
        <div class="center-box">
          <div class="big-word">${ms}ms</div>
          <div class="subline">이번 점수: ${score}</div>
          <button class="btn strong" id="retryCerebellumBtn">다시하기</button>
        </div>
      `
                );
                document.getElementById("retryCerebellumBtn").addEventListener("click", startSelectedGame);
            });

            setTimeout(() => {
                if (!activeGameState || activeGameState.type !== "cerebellum") return;
                if (activeGameState.clickedTooSoon) return;
                activeGameState.ready = true;
                activeGameState.startedAt = Date.now();
                reactionBox.textContent = "지금 클릭!";
                reactionBox.style.background = "#e7f7ee";
                reactionBox.style.borderColor = "#b8e5ca";
            }, waitMs);
        }

        function formatReaction(ms) {
            return ms === null || ms === undefined ? "-" : `${ms}ms`;
        }

        function calcAccuracy(correct, attempts) {
            if (!attempts) return "0%";
            return `${Math.round((correct / attempts) * 100)}%`;
        }

        function renderStats() {
            document.getElementById("totalPlaysValue").textContent = stats.totalPlays;
            document.getElementById("bestScoreValue").textContent = stats.bestScore;
            document.getElementById("accuracyValue").textContent = calcAccuracy(stats.totalCorrect, stats.totalAttempts);
            document.getElementById("bestReactionValue").textContent = formatReaction(stats.bestReaction);

            const detail = document.getElementById("detailStatsInModal");
            if (!detail) return; 

            detail.innerHTML = "";

            Object.values(regions).forEach(region => {
                const rs = stats.regions[region.key];
                const row = document.createElement("div");
                row.className = "detail-row";
                row.innerHTML = `
          <div class="detail-row-head">
            <span>${region.name}</span>
            <span>${region.description}</span>
          </div>
          <div class="detail-meta">
            <div>클리어 횟수<br><strong>${rs.plays}</strong></div>
            <div>최고 점수<br><strong>${rs.bestScore}</strong></div>
            <div>정답률<br><strong>${calcAccuracy(rs.correct, rs.attempts)}</strong></div>
            <div>최고 반응속도<br><strong>${formatReaction(rs.bestReaction)}</strong></div>
          </div>
        `;
                detail.appendChild(row);
            });

            renderQuickStatsModal();
        }

        function renderQuickStatsModal() {
            const body = document.getElementById("quickStatsModalBody");
            if (!body) return;
            body.innerHTML = `
        <div class="setting-item">전체 클리어: <strong>${stats.totalPlays}</strong></div>
        <div class="setting-item">전체 최고 점수: <strong>${stats.bestScore}</strong></div>
        <div class="setting-item">전체 정답률: <strong>${calcAccuracy(stats.totalCorrect, stats.totalAttempts)}</strong></div>
        <div class="setting-item">최고 반응속도: <strong>${formatReaction(stats.bestReaction)}</strong></div>
      `;
        }

        function openModal(id) { document.getElementById(id).classList.add("show"); }
        function closeModal(id) { document.getElementById(id).classList.remove("show"); }

        function syncSettingsUI() {
            document.getElementById("soundToggle").value = settings.effectText;
            document.getElementById("autoShowStats").value = settings.resultHint;
        }

        // 이벤트 리스너
        document.getElementById("startNowBtn").addEventListener("click", () => showScreen("main"));
        document.getElementById("statsNowBtn").addEventListener("click", () => { showScreen("main"); openModal("statsModal"); });
        document.getElementById("directMainBtn").addEventListener("click", () => showScreen("main"));
        document.getElementById("goHomeBtn").addEventListener("click", () => showScreen("start"));
        document.getElementById("openStatsBtn").addEventListener("click", () => openModal("statsModal"));
        document.getElementById("openSettingsBtn").addEventListener("click", () => openModal("settingsModal"));
        document.getElementById("closeSettingsBtn").addEventListener("click", () => closeModal("settingsModal"));
        document.getElementById("closeStatsBtn").addEventListener("click", () => closeModal("statsModal"));

        document.getElementById("resetStatsBtn").addEventListener("click", () => {
            if (!confirm("통계를 모두 초기화할까요?")) return;
            stats = defaultStats();
            saveStats();
            renderStats();
            showStatus("통계가 초기화되었습니다.");
        });

        difficultySelect.addEventListener("change", updateDifficultyUI);
        hardLevelSelect.addEventListener("change", updateDifficultyUI);

        document.getElementById("restartGameBtn").addEventListener("click", () => {
            if (!selectedRegionKey) return showStatus("먼저 뇌 영역을 선택해주세요.");
            startSelectedGame();
        });

        document.getElementById("soundToggle").addEventListener("change", (e) => {
            settings.effectText = e.target.value;
            saveSettings();
        });

        document.getElementById("autoShowStats").addEventListener("change", (e) => {
            settings.resultHint = e.target.value;
            saveSettings();
        });

        function clearRegionSelection() {
            selectedRegionKey = null;
            document.querySelectorAll(".region").forEach(el => el.classList.remove("active", "dimmed"));
            dimOverlay.style.display = "none";
            activeMaskPolygon.setAttribute("points", "");
            brainLabel.classList.remove("show");
        }

        // --- 페이지 초기 실행 함수들 ---
        // 시작하자마자 메인 화면(게임 선택)으로 이동하도록 추가
        showScreen("main");
        
        initRegions();
        renderStats();
        syncSettingsUI();
        updateDifficultyUI();
        clearRegionSelection();
    </script>
</body>

</html>
