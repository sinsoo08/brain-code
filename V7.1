<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BRAIN code · 시작</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700;900&display=swap" rel="stylesheet" />
    <style>
         :root {
            --bg: #E3F2FD;
            --surface: #FFFFFF;
            --text: #1A237E;
            --border: #333333;
        }
        
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        
        body {
            font-family: "Noto Sans KR", sans-serif;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .main-container {
            width: min(750px, 95vw);
            display: flex;
            flex-direction: column;
            gap: 25px;
        }
        /* 상단 헤더 */
        
        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .logo {
            font-size: 32px;
            font-weight: 900;
            color: var(--text);
        }
        
        .btn-settings {
            padding: 10px 20px;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: #fff;
            font-weight: 700;
            cursor: pointer;
        }
        /* 중간 영역: 프로필 & 시작 버튼 */
        
        .middle-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .profile {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .avatar {
            width: 70px;
            height: 70px;
            border: 2px solid var(--border);
            border-radius: 50%;
            background: #fff;
            display: grid;
            place-items: center;
            font-size: 35px;
        }
        
        .info {
            font-size: 16px;
            color: var(--text);
            line-height: 1.5;
            font-weight: 500;
        }
        
        .btn-start {
            padding: 15px 40px;
            font-size: 22px;
            font-weight: 900;
            border: 2.5px solid var(--border);
            border-radius: 40px;
            background: #fff;
            cursor: pointer;
            transition: 0.2s;
        }
        
        .btn-start:hover {
            background: #f0f0f0;
        }
        /* 하단 통계 박스 */
        
        .stats-box {
            width: 100%;
            height: 350px;
            background: #fff;
            border: 3px solid var(--border);
            border-radius: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.1s;
        }
        
        .stats-box:active {
            transform: scale(0.98);
        }
        
        .stats-title {
            font-size: 100px;
            font-weight: 900;
            letter-spacing: 15px;
            color: var(--text);
        }
        
        .stats-sub {
            font-size: 18px;
            font-weight: 700;
            color: #1E88E5;
            margin-top: 10px;
        }
    </style>
</head>

<body>
    <div class="main-container">
        <div class="header-row">
            <div class="logo">🧠 브레인 코드</div>
            <button class="btn-settings">설정</button>
        </div>
        <div class="middle-row">
            <div class="profile">
                <div class="avatar">👤</div>
                <div class="info">이름 ________<br>생일 ________</div>
            </div>
            <button class="btn-start" onclick="location.href='1.html'">게임 시작</button>
        </div>
        <div class="stats-box" onclick="goStats()">
            <div class="stats-title">통계</div>
            <div class="stats-sub"> </div>
        </div>
    </div>
    <script>
        function goStats() {
            // 통계 신호를 주소에 담아서 1.html로 보냄
            location.href = "1.html?showStats=true";
        }
    </script>
</body>

</html>
